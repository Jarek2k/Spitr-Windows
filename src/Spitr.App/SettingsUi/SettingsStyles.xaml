<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Gemeinsame Optik der Settings-Tabs: Karten-Gruppen mit Kopfzeile und
         Fußnote — das WPF-Pendant zum macOS-Grouped-Form-Stil. Die Grautöne
         sind halbtransparent, damit sie in Hell- und Dunkel-Theme funktionieren. -->

    <!-- Gruppen-Karte -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="#14808080"/>
        <Setter Property="BorderBrush" Value="#33808080"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Abschnitts-Überschrift über einer Karte -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="2,16,0,6"/>
    </Style>

    <!-- Erklärtext unter einer Karte (Pendant zum Form-Footer am Mac) -->
    <Style x:Key="Footnote" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Opacity" Value="0.65"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="2,6,2,0"/>
    </Style>

    <!-- Zeilen-Label links neben einem Steuerelement -->
    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

</ResourceDictionary>
