<Window x:Class="Spitr.App.SettingsUi.CorrectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spracheingabe korrigieren"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <!-- Port des macOS-CorrectionSheet: falsch erkanntes Wort antippen,
         Ersetzung eintippen, „Regel sichern" legt eine dauerhafte
         Wörterbuch-Regel an und korrigiert den Eintrag gleich mit. -->
    <StackPanel Margin="20">
        <TextBlock Text="Spracheingabe korrigieren" FontWeight="SemiBold" FontSize="14"/>
        <TextBlock Margin="0,6,0,12" FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                   Text="Tippe das falsch erkannte Wort an und gib ein, wodurch es ersetzt werden soll. Die Regel gilt dann automatisch für alle künftigen Spracheingaben."/>

        <!-- Die erkannten Wörter als antippbare „Chips" (WrapPanel-ListBox) -->
        <ListBox x:Name="WordsList" MaxHeight="140" Margin="0,0,0,12"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionMode="Single"
                 SelectionChanged="OnWordSelected"
                 AutomationProperties.AutomationId="Correction.Words">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Padding" Value="8,3"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Falsch erkannt" VerticalAlignment="Center" Margin="0,0,10,10"
                       HorizontalAlignment="Right" Opacity="0.8"/>
            <TextBox x:Name="WrongWordBox" Grid.Column="1" Margin="0,0,0,10"
                     TextChanged="OnFieldsChanged"
                     AutomationProperties.AutomationId="Correction.WrongWord"/>
            <TextBlock Text="Ersetzen durch" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,10,0"
                       HorizontalAlignment="Right" Opacity="0.8"/>
            <TextBox x:Name="ReplacementBox" Grid.Row="1" Grid.Column="1"
                     TextChanged="OnFieldsChanged"
                     AutomationProperties.AutomationId="Correction.Replacement"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" IsCancel="True" MinWidth="90"
                    AutomationProperties.AutomationId="Correction.Cancel"/>
            <Button x:Name="SaveButton" Content="Regel sichern" IsDefault="True" MinWidth="110" Margin="8,0,0,0"
                    Click="OnSaveClick" IsEnabled="False"
                    AutomationProperties.AutomationId="Correction.Save"/>
        </StackPanel>
    </StackPanel>
</Window>
