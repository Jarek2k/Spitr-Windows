<UserControl x:Class="Spitr.App.SettingsUi.VocabularySettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- „Vokabular": eigene Begriffe als Bias-Hint für die Erkennung — statt
         der Chips des macOS-Originals eine schlichte mehrzeilige TextBox,
         direkt an settings.VocabularyText gebunden (ein Begriff pro Zeile). -->
    <Grid Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Eigene Begriffe" Style="{StaticResource SectionHeader}" Margin="2,0,0,6"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="4">
            <TextBox x:Name="VocabularyBox"
                     Text="{Binding VocabularyText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     VerticalContentAlignment="Top"
                     AutomationProperties.AutomationId="Vocabulary.Text"/>
        </Border>

        <StackPanel Grid.Row="2">
            <TextBlock Style="{StaticResource Footnote}"
                       Text="Ein Begriff pro Zeile. Eigennamen und Fachbegriffe werden der Erkennung als Hinweis mitgegeben — das hilft oft, ist aber nicht garantiert. Trifft die Erkennung ein Wort nie, trag es im Wörterbuch als feste Ersetzung ein."/>
            <TextBlock Style="{StaticResource Footnote}"
                       Text="Beispiel: Claude, Xcode, WPF, Parnas — jeweils in einer eigenen Zeile."/>
        </StackPanel>
    </Grid>
</UserControl>
