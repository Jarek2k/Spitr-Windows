<UserControl x:Class="Spitr.App.SettingsUi.HistorySettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- „Verlauf": letzte Spracheingaben mit Kopieren/Korrigieren/Löschen —
         Port von HistorySettingsView.swift (inkl. Korrektur-Dialog). -->
    <Grid Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}">
            <CheckBox Content="Verlauf aufzeichnen"
                      IsChecked="{Binding Enabled}"
                      AutomationProperties.AutomationId="History.EnabledToggle"/>
        </Border>

        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Letzte Spracheingaben" Style="{StaticResource SectionHeader}" Margin="2,12,0,6"/>
            <Button x:Name="ClearAllButton" Grid.Column="1" Content="Alle löschen"
                    VerticalAlignment="Bottom" Margin="0,0,0,6"
                    Click="OnClearAllClick"
                    AutomationProperties.AutomationId="History.ClearAll"/>
        </Grid>

        <Grid Grid.Row="2">
            <ListView x:Name="EntriesList"
                      SelectionMode="Single"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      AutomationProperties.AutomationId="History.List">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           MaxHeight="72" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Timestamp}" FontSize="11" Opacity="0.65" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Top" Margin="8,0,0,0">
                                <Button Content="Kopieren" Click="OnCopyClick" Margin="0,0,6,0"
                                        AutomationProperties.AutomationId="History.Item.Copy"/>
                                <Button Content="Korrigieren…" Click="OnCorrectClick" Margin="0,0,6,0"
                                        AutomationProperties.AutomationId="History.Item.Correct"/>
                                <Button Content="Löschen" Click="OnDeleteClick"
                                        AutomationProperties.AutomationId="History.Item.Delete"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <!-- Leer-Zustand über der (leeren) Liste -->
            <TextBlock x:Name="EmptyHint" Text="Noch keine Spracheingaben."
                       Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
